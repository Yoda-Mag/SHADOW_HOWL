# ============================================
# Shadow Howl - Frontend Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit this file to version control!
#
# IMPORTANT: Different configs for local vs production:
#
# LOCAL DEVELOPMENT:
# VITE_API_URL=http://localhost:5000/api
#
# PRODUCTION (Lightsail):
# VITE_API_URL=http://18.134.190.37/api
# (GitHub Actions will set this from VITE_API_URL secret)

# ============================================
# API Configuration
# ============================================
# This will be overridden by CI/CD pipeline
VITE_API_URL=http://localhost:5000/api

# ============================================
# Environment
# ============================================
# This is automatically set by Vite based on build/dev mode
# VITE_ENV=development

# ============================================
# Feature Flags (Optional)
# ============================================
# VITE_ENABLE_DEBUG=false
# VITE_LOG_LEVEL=info
