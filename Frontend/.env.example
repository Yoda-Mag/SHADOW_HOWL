# ============================================
# Shadow Howl - Frontend Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# API Configuration
# ============================================
# Development: http://localhost:5000/api
# Production: Use /api (same origin via Nginx proxy)
VITE_API_URL=http://localhost:5000/api

# ============================================
# Environment
# ============================================
# This is automatically set by Vite based on build/dev mode
# VITE_ENV=development

# ============================================
# Feature Flags (Optional)
# ============================================
# VITE_ENABLE_DEBUG=false
# VITE_LOG_LEVEL=info
