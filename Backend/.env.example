# ============================================
# Shadow Howl - Backend Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Database Configuration (AWS Lightsail)
# ============================================
# Use 127.0.0.1 if database is on same instance
# Use hostname if on RDS or separate instance
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=shadow_user
DB_PASSWORD=your_strong_database_password_here
DB_NAME=shadow_howl

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# ============================================
# Authentication & Security
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_generate_random_32_chars

# ============================================
# Third-party API Keys
# ============================================
# Get from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Get from Resend: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here

# ============================================
# CORS Configuration (Optional)
# ============================================
# Add additional allowed origins if needed
# ALLOWED_ORIGIN=https://yourdomain.com

# ============================================
# Email Configuration
# ============================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SENDER_EMAIL=noreply@example.com

# ============================================
# Payment Gateway (When implemented)
# ============================================
# PAYGATE_MERCHANT_ID=your_merchant_id
# PAYGATE_API_KEY=your_api_key